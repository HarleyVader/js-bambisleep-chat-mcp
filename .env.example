# Environment Variables for BambiSleep Analyzer MCP Server
# Copy this file to .env and modify as needed

# Node.js Environment
NODE_ENV=production

# Server Configuration
PORT=3000
LOG_LEVEL=info

# Milvus Configuration
MILVUS_URI=http://milvus:19530
MILVUS_COLLECTION=bambisleep_data

# Memory Adapter Configuration
MEMORY_PERSISTENT=true
MEMORY_STORAGE_PATH=/app/data/memory

# DuckDuckGo Configuration
DUCKDUCKGO_TIMEOUT=10000
DUCKDUCKGO_MAX_RESULTS=30

# Fetch Adapter Configuration
FETCH_TIMEOUT=15000
FETCH_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36"